<Page x:Class="App_Farmacia.PaginaClientes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestión de Clientes" Background="White">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Clientes Registrados" Grid.Row="0" Margin="0,0,10,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Buscar Cliente:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtBuscarCliente" Width="200" Height="25" 
                             ToolTip="Ingrese nombre o documento"/>
                    <Button Content="Buscar" Width="75" Height="25" Margin="10,0,0,0"
                            Background="#34495E" Foreground="White"
                            Click="BtnBuscar_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgClientes" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionChanged="dgClientes_SelectionChanged" Margin="0,10,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID_Cliente}" Width="50"/>
                        <DataGridTextColumn Header="Nombre Completo" Binding="{Binding Nombre}" Width="*"/>
                        <DataGridTextColumn Header="Documento" Binding="{Binding NroDocumento}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <GroupBox Header="Historial de Compras" Grid.Row="1" Margin="0,0,10,0">
            <DataGrid x:Name="dgHistorial" AutoGenerateColumns="False" IsReadOnly="True" Background="#F2F4F4">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=\{0:dd/MM/yyyy\}}" Width="120"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="100"/>
                    <DataGridTextColumn Header="Sucursal" Binding="{Binding Sucursal}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Column="1" Grid.RowSpan="2">
            <GroupBox Header="Nuevo Cliente">
                <Border Padding="15">
                    <StackPanel>
                        <TextBlock Text="Primer Nombre:"/>
                        <TextBox x:Name="txtNombre" Margin="0,5"/>
                        <TextBlock Text="Primer Apellido:"/>
                        <TextBox x:Name="txtApellido" Margin="0,5"/>
                        <TextBlock Text="Nro. Documento:"/>
                        <TextBox x:Name="txtDocumento" Margin="0,5"/>
                        <TextBlock Text="Correo:"/>
                        <TextBox x:Name="txtCorreo" Margin="0,5"/>
                        <Button Content="REGISTRAR CLIENTE" Height="40" Margin="0,15,0,0" 
                                Background="#2C3E50" Foreground="White" FontWeight="Bold"
                                Click="BtnRegistrar_Click"/>
                    </StackPanel>
                </Border>
            </GroupBox>
        </StackPanel>
    </Grid>
</Page>